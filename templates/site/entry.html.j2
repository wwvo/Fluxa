{% extends "base.html.j2" %}

{% set page_title = entry.title %}
{% set page_description = entry.summary or entry.title %}

{% block top_actions %}
  {% if entry.url %}
    <a class="text-link" href="{{ entry.url }}">查看原文</a>
  {% endif %}
{% endblock %}

{% block content %}
  <section class="hero-card hero-card-compact">
    <p class="eyebrow">{{ entry.feed_title }}</p>
    <h1>{{ entry.title }}</h1>
    {% if entry.summary %}
      <p class="hero-copy">{{ entry.summary }}</p>
    {% endif %}
    <div class="meta-row">
      {% if entry.published_at %}
        <span>发布时间：{{ entry.published_at }}</span>
      {% endif %}
      <span>来源：{{ entry.feed_title }}</span>
    </div>
    <div class="hero-actions">
      <a class="button-link" href="{{ home_url }}">返回首页</a>
      {% if entry.url %}
        <a class="text-link" href="{{ entry.url }}">查看原文</a>
      {% endif %}
    </div>
  </section>

  {% if content_html %}
  <article class="markdown-body">
    {{ content_html | safe }}
  </article>
  {% endif %}
{% endblock %}
