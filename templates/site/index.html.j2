{% extends "base.html.j2" %}

{% set page_title = "文章列表" %}
{% set page_description = "Fluxa Digest 历史归档" %}

{% block content %}
  <section class="hero-card">
    <p class="eyebrow">Fluxa Digest</p>
    <h1>历史归档</h1>
    <p class="hero-copy">
      由 Fluxa 自动抓取并发布的 RSS 摘要，每轮运行一期。
    </p>
  </section>

  <section class="doc-grid">
    {% for digest in digests %}
      <article class="doc-card">
        <div class="doc-card-head">
          <h2><a href="{{ digest.page_url }}">{{ digest.issue_date }} · {{ digest.display_key }}</a></h2>
          <span class="doc-meta">新增 {{ digest.new_count }} 篇</span>
        </div>
        <p class="doc-summary">{{ digest.issue_title }}</p>
        <div class="doc-card-actions">
          <a class="button-link" href="{{ digest.page_url }}">查看详情</a>
        </div>
      </article>
    {% else %}
      <article class="doc-card doc-card-empty">
        <h2>暂无归档</h2>
        <p class="doc-summary">等待首次 RSS 同步运行。</p>
      </article>
    {% endfor %}
  </section>
{% endblock %}
